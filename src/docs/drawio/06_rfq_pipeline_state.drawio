        </mxCell>
        <mxCell id="14" value="LOST status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="340" width="100" height="36" as="geometry" />
