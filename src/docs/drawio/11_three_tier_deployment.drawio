        <mxCell id="24" value="customer / rfq /&#xa;campaign / inventory /&#xa;integration modules" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="20">
