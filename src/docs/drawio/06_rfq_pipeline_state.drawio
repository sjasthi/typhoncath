        <mxCell id="11" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="635" y="690" width="40" height="40" as="geometry" />
