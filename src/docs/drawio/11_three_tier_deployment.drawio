        <!-- ===== SECURITY CALLOUTS ===== -->
        <mxCell id="50" value="Security: bcrypt password hashing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="640" width="200" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="51" value="Security: PHP sessions + RBAC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;dashed=1;" vertex="1" parent="1">
