<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="RFQ Pipeline State">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1000" pageHeight="750" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="RFQ Pipeline State Diagram" style="text;html=1;align=center;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- Start node -->
        <mxCell id="3" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="430" y="70" width="40" height="40" as="geometry" />
        </mxCell>

        <!-- States: New, In Review, Quoted, Negotiation, Won, Lost -->
        <mxCell id="4" value="New" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="150" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="5" value="In Review" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="265" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="6" value="Quoted" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="380" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="7" value="Negotiation" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="495" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="8" value="Won" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="600" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="9" value="Lost" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="600" width="130" height="60" as="geometry" />
        </mxCell>

        <!-- End nodes -->
        <mxCell id="10" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="245" y="690" width="40" height="40" as="geometry" />
