          </mxGeometry>
        </mxCell>

        <!-- Negotiation -> Quoted (revise quote) -->
        <mxCell id="28" value="revise quote" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;exitX=0;exitY=0.4;entryX=0;entryY=0.6;dashed=1;" edge="1" parent="1" source="7" target="6">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
