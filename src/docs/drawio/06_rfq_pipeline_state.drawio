        </mxCell>

        <!-- Negotiation -> Won -->
        <mxCell id="24" value="customer accepts" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="7" target="8">
