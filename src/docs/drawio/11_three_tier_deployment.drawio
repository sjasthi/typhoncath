<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Three-Tier Deployment">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="Three-Tier Deployment Architecture" style="text;html=1;align=center;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="700" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== TIER 1: PRESENTATION LAYER ===== -->
        <mxCell id="10" value="Presentation Layer" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="55" width="980" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="User Browser&#xa;Chrome / Firefox / Safari" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="10">
          <mxGeometry x="40" y="50" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="HTML5 + CSS3&#xa;JavaScript / jQuery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="10">
          <mxGeometry x="260" y="50" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="Bootstrap&#xa;Responsive UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="10">
          <mxGeometry x="460" y="50" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== TIER 2: APPLICATION LAYER ===== -->
        <mxCell id="20" value="Application Layer" style="swimlane;startSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="230" width="980" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="Apache / Nginx&#xa;Web Server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="40" y="50" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="22" value="PHP Monolithic CRM&#xa;/modules /includes /config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="240" y="50" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="23" value="Auth / Session&#xa;RBAC Checks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="20">
