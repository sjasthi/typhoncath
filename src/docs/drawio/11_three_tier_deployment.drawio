        <!-- GitHub -> Hosting -->
        <mxCell id="78" value="deploy / FTP / upload" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="41" target="33">
