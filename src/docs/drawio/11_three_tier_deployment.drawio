        <!-- Error logs -->
        <mxCell id="25" value="Error Logs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="20">
          <mxGeometry x="240" y="150" width="120" height="35" as="geometry"/>
        </mxCell>

        <!-- ===== TIER 3: DATA LAYER ===== -->
        <mxCell id="30" value="Data Layer" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="465" width="980" height="150" as="geometry"/>
