        <!-- Open status legend box -->
        <mxCell id="12" value="OPEN status:&#xa;New, In Review, Quoted, Negotiation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;dashed=1;" vertex="1" parent="1">
