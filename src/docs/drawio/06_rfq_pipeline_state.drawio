        <mxCell id="200" value="Pipeline Status Legend" style="text;html=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="230" width="220" height="24" as="geometry" />
        </mxCell>

        <!-- TRANSITIONS -->
        <!-- Start -> New -->
        <mxCell id="20" value="RFQ created" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;" edge="1" parent="1" source="3" target="4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- New -> In Review -->
        <mxCell id="21" value="sales review starts" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;" edge="1" parent="1" source="4" target="5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- In Review -> Quoted -->
        <mxCell id="22" value="quote prepared" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;" edge="1" parent="1" source="5" target="6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Quoted -> Negotiation -->
        <mxCell id="23" value="customer responds" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;" edge="1" parent="1" source="6" target="7">
